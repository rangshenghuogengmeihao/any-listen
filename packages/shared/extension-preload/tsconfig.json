{
  "extends": "@any-listen/eslint/tsconfig.json",
  "compilerOptions": {
    "lib": ["ESNext"],
    "composite": true,
    "target": "ESNext",
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "types": ["@any-listen/types"],
    "rootDir": "./",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.js"],
  "exclude": ["**/node_modules/@types/node/globals.d.ts"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
